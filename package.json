{
  "name": "cs-stonks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "npm run db:local:setup && next dev",
    "dev:docker": "npm run db:docker:setup && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:local:setup": "node ./scripts/local-db-bootstrap.mjs setup",
    "db:local:start": "node ./scripts/local-db-bootstrap.mjs start",
    "db:local:status": "node ./scripts/local-db-bootstrap.mjs status",
    "db:local:stop": "node ./scripts/local-db-bootstrap.mjs stop",
    "db:docker:setup": "node ./scripts/docker-db-bootstrap.mjs setup",
    "db:docker:up": "node ./scripts/docker-db-bootstrap.mjs up",
    "db:docker:status": "node ./scripts/docker-db-bootstrap.mjs status",
    "db:docker:down": "node ./scripts/docker-db-bootstrap.mjs down",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "job:catalog": "node --env-file=.env --import tsx ./src/modules/catalog/jobs/runCatalogSyncJob.ts",
    "job:catalog:refresh-images": "node --env-file=.env --import tsx ./src/modules/catalog/jobs/runCatalogImageRefreshJob.ts",
    "job:prices": "node --env-file=.env --import tsx ./src/modules/pricing/jobs/runLatestPricesSyncJob.ts",
    "job:snapshot": "node --env-file=.env --import tsx ./src/modules/snapshots/jobs/runDailySnapshotJob.ts",
    "jobs:scheduler": "node --env-file=.env --import tsx ./src/modules/jobs/registerCronJobs.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.8.0",
    "next": "15.5.15",
    "node-cron": "^4.2.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.3",
    "eslint": "^9",
    "eslint-config-next": "15.5.15",
    "prisma": "^6.18.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.0.3"
  }
}
